<?xml version="1.0" encoding="utf-8" ?>
<configuration>

	<connectionStrings>

		<add
		  name="CompanyDB"
		  connectionString="
      Server=.\SQLEXPRESS;
      Database=CompanyDB;
      Trusted_Connection=True;
      TrustServerCertificate=True;"
		  providerName="System.Data.SqlClient"/>

	</connectionStrings>

</configuration>